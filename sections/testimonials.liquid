<section class="testimonials-section">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: "What Our Customers Say" }}</h2>
      <p class="testimonials-aggregate__text">{{ section.settings.aggregate_text }}</p>
    </div>

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-stars">
            {% assign stars = block.settings.rating | default: 5 %}
            {% for i in (1..5) %}
              {% if i <= stars %}
                <svg class="star star--filled" width="18" height="18" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#facc15"/></svg>
              {% else %}
                <svg class="star" width="18" height="18" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#e5e7eb"/></svg>
              {% endif %}
            {% endfor %}
          </div>
          <blockquote class="testimonial-quote">
            "{{ block.settings.quote }}"
          </blockquote>
          <div class="testimonial-author">
            {% if block.settings.avatar != blank %}
              <div class="testimonial-avatar">
                {{ block.settings.avatar | image_url: width: 80 | image_tag }}
              </div>
            {% else %}
              <div class="testimonial-avatar testimonial-avatar--placeholder">
                {{ block.settings.author | slice: 0 }}
              </div>
            {% endif %}
            <div class="testimonial-author-info">
              <strong>{{ block.settings.author }}</strong>
              {% if block.settings.verified %}
                <span class="testimonial-verified">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Verified Buyer
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: var(--spacing-xl) 0;
    background: var(--color-bg-alt);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
  }

  .testimonial-card {
    background: var(--color-bg);
    border-radius: 12px;
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    border-color: transparent;
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
  }

  .star--filled path {
    fill: #facc15 !important;
  }

  .star path {
    fill: #e5e7eb;
  }

  .testimonial-quote {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    flex: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-avatar--placeholder {
    background: linear-gradient(135deg, var(--color-accent), #ff6b8a);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
  }

  .testimonial-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .testimonial-author-info strong {
    font-size: 0.9rem;
  }

  .testimonial-verified {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: #10b981;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "aggregate_text",
      "label": "Aggregate rating text",
      "default": "We'd love to hear from you — leave a review after your purchase!"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Absolutely love the quality! The fabric is so soft and the print hasn't faded after multiple washes."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author photo"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": []
    }
  ]
}
{% endschema %}
