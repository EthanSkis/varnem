<section class="about-section">
  <div class="container">
    <div class="about-hero">
      <h1>{{ section.settings.heading }}</h1>
      <p class="about-lead">{{ section.settings.lead }}</p>
    </div>

    <div class="about-story">
      <div class="about-story__text">
        <h2>{{ section.settings.story_heading }}</h2>
        <p>{{ section.settings.story_text_1 }}</p>
        <p>{{ section.settings.story_text_2 }}</p>
      </div>
      <div class="about-story__image">
        {% if section.settings.story_image != blank %}
          {{ section.settings.story_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <div class="about-image-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><path d="M20.38 3.46 16 2 12 5.5 8 2 3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/></svg>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="about-values">
      <h2 class="about-values__heading">{{ section.settings.values_heading }}</h2>
      <div class="about-values__grid">
        {% for block in section.blocks %}
          <div class="about-value" {{ block.shopify_attributes }}>
            <div class="about-value__icon">
              {% case block.settings.icon %}
                {% when 'heart' %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {% when 'globe' %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {% when 'smile' %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                {% when 'leaf' %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22c1.25-1.25 2.5-2 4-2 3 0 4 3 8 3s5.5-2 7-4"/><path d="M3.47 12.53a6 6 0 0 1 8.06-8.06C13 5.53 14 7.47 14 10c0 4-2 6-6 6-2.53 0-4.47-1-5.53-2.47z"/><path d="M14 10c0 4 2 6 6 6 2.53 0 4.47-1 5.53-2.47a6 6 0 0 0-8.06-8.06C16 6.53 14 7.47 14 10z"/></svg>
              {% endcase %}
            </div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="about-cta">
      <h2>{{ section.settings.cta_heading }}</h2>
      <p>{{ section.settings.cta_text }}</p>
      <a href="{{ section.settings.cta_link }}" class="btn btn-primary btn-lg">
        {{ section.settings.cta_button }}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: var(--spacing-xl) 0;
  }

  .about-hero {
    text-align: center;
    max-width: 750px;
    margin: 0 auto var(--spacing-xl);
  }

  .about-hero h1 {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: -1px;
    margin-bottom: var(--spacing-sm);
  }

  .about-lead {
    font-size: 1.2rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .about-story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
    margin-bottom: var(--spacing-xl);
  }

  .about-story__text h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: var(--spacing-sm);
    letter-spacing: -0.5px;
  }

  .about-story__text p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .about-story__image {
    border-radius: 12px;
    overflow: hidden;
  }

  .about-story__image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  .about-image-placeholder {
    aspect-ratio: 4/3;
    background: var(--color-bg-alt);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-values {
    margin-bottom: var(--spacing-xl);
  }

  .about-values__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: var(--spacing-lg);
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-md);
  }

  .about-value {
    text-align: center;
    padding: var(--spacing-md);
    background: var(--color-bg-alt);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .about-value__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--spacing-sm);
    background: linear-gradient(135deg, var(--color-accent), #ff6b8a);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-value h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .about-value p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .about-cta {
    text-align: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    padding: var(--spacing-lg);
    border-radius: 16px;
  }

  .about-cta h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .about-cta p {
    opacity: 0.9;
    margin-bottom: var(--spacing-md);
    font-size: 1.05rem;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .about-hero h1 {
      font-size: 2.2rem;
    }

    .about-story {
      grid-template-columns: 1fr;
    }

    .about-values__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We Make Shirts That Make People Smile"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead paragraph",
      "default": "FunShirts.us started with a simple idea: life's too short for boring clothes. We design tees and accessories that spark joy, start conversations, and feel incredible to wear."
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story heading",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "story_text_1",
      "label": "Story paragraph 1",
      "default": "It all started when we couldn't find a t-shirt brand that nailed both quality and personality. Everything was either cheap fabric with a funny print, or premium quality with zero personality. We thought: why not both?"
    },
    {
      "type": "textarea",
      "id": "story_text_2",
      "label": "Story paragraph 2",
      "default": "Today, every FunShirts design is printed on 100% ring-spun cotton using eco-friendly water-based inks. We obsess over the details so you don't have to - from the weight of the fabric to the softness of the collar. The result? Tees that get softer with every wash and prints that never crack or fade."
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story image"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values heading",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Ready to Upgrade Your Wardrobe?"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Join thousands of happy customers wearing the comfiest, funniest shirts on the planet."
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "heart", "label": "Heart" },
            { "value": "globe", "label": "Globe" },
            { "value": "smile", "label": "Smile" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "heart"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Quality First"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "We never cut corners on materials or craftsmanship."
        }
      ]
    }
  ]
}
{% endschema %}
