<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="site-logo" style="font-size:1.3rem; margin-bottom:0.5rem;">{{ section.settings.logo_text | default: shop.name }}</div>
        <p>{{ section.settings.description | default: "Making shirts that bring smiles since day one. Premium quality, fun designs, and a brand that doesn't take itself too seriously." }}</p>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            {% if block.settings.menu != blank %}
              <ul>
                {% for link in linklists[block.settings.menu].links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "FunShirts"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Making shirts that bring smiles since day one. Premium quality, fun designs, and a brand that doesn't take itself too seriously."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Help",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
