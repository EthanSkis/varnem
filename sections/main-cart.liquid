<section style="padding: var(--spacing-xl) 0;">
  <div class="container">
    <h1 style="font-size:2rem; font-weight:800; margin-bottom:var(--spacing-md);">Your Cart</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post">
        {% for item in cart.items %}
          <div class="cart-line" style="display:flex; gap:var(--spacing-sm); padding:var(--spacing-sm) 0; border-bottom:1px solid var(--color-border); align-items:center;">
            <div style="width:80px; height:80px; flex-shrink:0;">
              {% if item.image != blank %}
                {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
            <div class="cart-line__info">
              <a href="{{ item.url }}" style="font-weight:600;">{{ item.product.title }}</a>
              {% if item.variant.title != 'Default Title' %}
                <p style="font-size:0.85rem; color:var(--color-text-light);">{{ item.variant.title }}</p>
              {% endif %}
            </div>
            <div class="cart-qty" role="group" aria-label="Change quantity for {{ item.product.title | escape }}">
              {% if item.quantity > 1 %}
                <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="cart-qty-btn cart-qty-btn--minus" aria-label="Decrease quantity of {{ item.product.title | escape }}">&minus;</a>
              {% else %}
                <span class="cart-qty-btn cart-qty-btn--minus is-disabled" aria-hidden="true">&minus;</span>
              {% endif %}
              <span class="cart-qty-value" aria-live="polite">{{ item.quantity }}</span>
              <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="cart-qty-btn cart-qty-btn--plus" aria-label="Increase quantity of {{ item.product.title | escape }}">+</a>
            </div>
            <div style="font-weight:600; color:var(--color-accent);">{{ item.line_price | money }}</div>
            <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-remove" aria-label="Remove {{ item.product.title }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            </a>
          </div>
        {% endfor %}

        <div style="text-align:right; padding:var(--spacing-md) 0;">
          <p style="font-size:1.2rem; font-weight:700; margin-bottom:var(--spacing-sm);">Subtotal: {{ cart.total_price | money }}</p>
          <button type="submit" name="checkout" class="btn btn-primary">Checkout</button>
        </div>
      </form>
    {% else %}
      <p style="text-align:center; color:var(--color-text-light); padding:var(--spacing-lg) 0;">Your cart is empty.</p>
      <div style="text-align:center;">
        <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
