<section class="hero-section">
  <div class="hero-content">
    <div class="hero-text">
      {% if section.settings.social_proof_text != blank %}
        <div class="hero-social-proof">
          <span>{{ section.settings.social_proof_text }}</span>
        </div>
      {% endif %}
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="hero-buttons">
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn-primary btn-lg">
            {{ section.settings.button_text }}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>
      <div class="hero-guarantees">
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Fast Shipping</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> 24/7 Support</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Secure Checkout</span>
      </div>
    </div>
    <div class="hero-visual">
      {% if section.settings.image != blank %}
        <div class="hero-image-wrapper">
          {{ section.settings.image | image_url: width: 600 | image_tag: loading: 'eager' }}
        </div>
      {% elsif section.settings.image_url != blank %}
        <div class="hero-image-wrapper">
          <img src="{{ section.settings.image_url }}" alt="{{ section.settings.heading }}" loading="eager" width="600">
        </div>
      {% else %}
        <div class="hero-image-wrapper">
          <img src="{{ 'hero-image.png' | asset_url }}" alt="{{ section.settings.heading }}" loading="eager" width="600">
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text",
      "default": "Premium Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spring Sale Now On"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Need help or have a query? Click on 'contact us' button below! We offer 24/7 phone support."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Hero image URL (alternative to picker)"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
