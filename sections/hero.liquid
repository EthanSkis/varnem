<section class="hero-section">
  <div class="hero-content">
    <div class="hero-text">
      <h1>{{ section.settings.heading | default: "Wear Your <span class='accent'>Personality</span>" }}</h1>
      <p>{{ section.settings.subheading | default: "Premium quality tees that make a statement. Bold designs, soft fabric, and a fit that feels just right." }}</p>
      <div class="hero-buttons">
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn-primary">{{ section.settings.button_text }}</a>
        {% endif %}
        {% if section.settings.secondary_button_text != blank %}
          <a href="{{ section.settings.secondary_button_link }}" class="btn btn-secondary">{{ section.settings.secondary_button_text }}</a>
        {% endif %}
      </div>
    </div>
    <div class="hero-visual">
      {% if section.settings.image != blank %}
        <div class="hero-image-wrapper">
          {{ section.settings.image | image_url: width: 600 | image_tag: loading: 'eager' }}
          {% if section.settings.badge_text != blank %}
            <div class="hero-badge">
              <span class="badge-text">{{ section.settings.badge_label }}</span>
              <span class="badge-value">{{ section.settings.badge_text }}</span>
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="hero-image-wrapper" style="background: rgba(255,255,255,0.05); border-radius: 16px; width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center;">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.38 3.46 16 2 12 5.5 8 2 3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>
          </svg>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Wear Your <span class='accent'>Personality</span>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium quality tees that make a statement. Bold designs, soft fabric, and a fit that feels just right."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge label",
      "default": "NEW"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "2026"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
