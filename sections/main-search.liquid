<section class="search-section" style="padding: var(--spacing-xl) 0;">
  <div class="container">
    <div class="section-header">
      <h1 style="font-size: 2.5rem; font-weight: 800;">Search</h1>
      {% if search.performed %}
        <p>
          {{ search.results_count }}
          {% if search.results_count == 1 %}result{% else %}results{% endif %}
          for &ldquo;{{ search.terms }}&rdquo;
        </p>
      {% else %}
        <p>Find your next favorite product.</p>
      {% endif %}
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="hidden" name="type" value="product">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search products..."
        aria-label="Search"
        autocomplete="off"
      >
      <button type="submit" class="btn btn-primary">Search</button>
    </form>

    {% paginate search.results by 24 %}
      {% if search.performed %}
        {% if search.results_count > 0 %}
          <div class="products-grid">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                <a href="{{ item.url }}" class="product-card">
                  <div class="product-card-image">
                    {% if item.featured_image != blank %}
                      {{ item.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                    {% else %}
                      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--color-bg-alt);">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                      </div>
                    {% endif %}
                  </div>
                  <div class="product-card-body">
                    {% if item.vendor != blank %}
                      <div class="product-card-vendor">{{ item.vendor }}</div>
                    {% endif %}
                    <h3 class="product-card-title">{{ item.title }}</h3>
                    <div class="product-card-price">{{ item.price | money }}</div>
                  </div>
                </a>
              {% else %}
                <a href="{{ item.url }}" class="search-result-card">
                  <div class="search-result-type">{{ item.object_type }}</div>
                  <h3>{{ item.title }}</h3>
                  {% if item.excerpt != blank %}
                    <p>{{ item.excerpt | strip_html | truncatewords: 24 }}</p>
                  {% elsif item.content != blank %}
                    <p>{{ item.content | strip_html | truncatewords: 24 }}</p>
                  {% endif %}
                </a>
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="search-pagination">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        {% else %}
          <div class="search-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <p>No results found for &ldquo;{{ search.terms }}&rdquo;.</p>
            <p class="search-empty__hint">Try a different keyword or check your spelling.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Browse all products</a>
          </div>
        {% endif %}
      {% endif %}
    {% endpaginate %}
  </div>
</section>

<style>
  .search-form {
    display: flex;
    gap: 0.5rem;
    max-width: 600px;
    margin: 0 auto var(--spacing-lg);
  }

  .search-form input[type="search"] {
    flex: 1;
    min-width: 0;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text);
  }

  .search-form input[type="search"]:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-tint);
  }

  .search-result-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-sm);
    border: 1px solid var(--color-border-light);
    border-radius: var(--border-radius);
    background: var(--color-bg);
    transition: all var(--transition);
  }

  .search-result-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .search-result-type {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 0.4rem;
  }

  .search-result-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: var(--color-primary);
  }

  .search-result-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  .search-empty {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    padding: var(--spacing-lg) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .search-empty p {
    font-size: 1.05rem;
    color: var(--color-text);
    margin: 0.5rem 0 0;
  }

  .search-empty__hint {
    font-size: 0.9rem !important;
    color: var(--color-text-light) !important;
    margin: 0 0 var(--spacing-sm) !important;
  }

  .search-pagination {
    text-align: center;
    margin-top: var(--spacing-lg);
  }

  .search-pagination a,
  .search-pagination span {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    margin: 0 0.15rem;
    border-radius: var(--border-radius);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .search-pagination a:hover {
    background: var(--color-primary-tint);
  }

  .search-pagination .current {
    background: var(--color-primary);
    color: #ffffff;
  }

  @media (max-width: 480px) {
    .search-form {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "settings": []
}
{% endschema %}
