<section class="features-section">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: "Why FunShirts?" }}</h2>
      <p>{{ section.settings.subheading | default: "Here's what makes us different" }}</p>
    </div>

    <div class="features-grid">
      {% for block in section.blocks %}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-icon">
            {% case block.settings.icon %}
              {% when 'quality' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
              {% when 'shipping' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'returns' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              {% when 'eco' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22c1.25-1.25 2.5-2 4-2 3 0 4 3 8 3s5.5-2 7-4"/><path d="M3.47 12.53a6 6 0 0 1 8.06-8.06C13 5.53 14 7.47 14 10c0 4-2 6-6 6-2.53 0-4.47-1-5.53-2.47z"/><path d="M14 10c0 4 2 6 6 6 2.53 0 4.47-1 5.53-2.47a6 6 0 0 0-8.06-8.06C16 6.53 14 7.47 14 10z"/></svg>
              {% else %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            {% endcase %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why FunShirts?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Here's what makes us different"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "quality", "label": "Star (Quality)" },
            { "value": "shipping", "label": "Truck (Shipping)" },
            { "value": "returns", "label": "Shield (Returns)" },
            { "value": "eco", "label": "Leaf (Sustainable)" }
          ],
          "default": "quality"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Quality"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Made from the finest materials for comfort that lasts all day."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "quality",
            "title": "Premium Quality",
            "description": "100% soft-spun cotton that feels amazing against your skin."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "description": "Free shipping on all orders over $50. No hidden fees."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "returns",
            "title": "Easy Returns",
            "description": "Not the right fit? Return it within 30 days, no questions asked."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "eco",
            "title": "Sustainable",
            "description": "Eco-friendly inks and ethically sourced materials."
          }
        }
      ]
    }
  ]
}
{% endschema %}
