<section class="features-section">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: "Why FunShirts?" }}</h2>
      <p>{{ section.settings.subheading | default: "Here's what makes us different" }}</p>
    </div>

    <div class="features-grid">
      {% for block in section.blocks %}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-icon">
            <span style="color: white; font-size: 1.5rem;">{{ block.settings.icon }}</span>
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why FunShirts?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Here's what makes us different"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "★"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Quality"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Made from the finest materials for comfort that lasts all day."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "★",
            "title": "Premium Quality",
            "description": "100% soft-spun cotton that feels amazing against your skin."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🚚",
            "title": "Free Shipping",
            "description": "Free shipping on all orders over $50. No hidden fees."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "↩",
            "title": "Easy Returns",
            "description": "Not the right fit? Return it within 30 days, no questions asked."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "♻",
            "title": "Sustainable",
            "description": "Eco-friendly inks and ethically sourced materials."
          }
        }
      ]
    }
  ]
}
{% endschema %}
