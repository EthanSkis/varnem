<section class="newsletter-section">
  <div class="container">
    <h2>{{ section.settings.heading | default: "Get 10% Off Your First Order" }}</h2>
    <p>{{ section.settings.subheading | default: "Join 1,000+ subscribers who get early access to new drops, exclusive discounts, and free shipping offers." }}</p>
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
        aria-label="{{ 'newsletter.label' | t }}"
        required
        autocomplete="email"
        value="{% if form.errors %}{{ form.email }}{% endif %}"
      >
      <button type="submit" class="btn btn-primary">{{ section.settings.button_text | default: "Get My 10% Off" }}</button>
      {% if form.posted_successfully? %}
        <div class="newsletter-message newsletter-message--success" role="status">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ 'newsletter.success' | t }}</span>
        </div>
      {% elsif form.errors %}
        <div class="newsletter-message newsletter-message--error" role="alert">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
    {% endform %}
    <div class="newsletter-trust">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      No spam, ever. Unsubscribe anytime.
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Be the first to know about new drops, exclusive discounts, and free shipping offers."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get My 10% Off"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
