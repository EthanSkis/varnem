<section class="rich-text-section" style="background: {{ section.settings.background_color }};">
  <div class="container">
    <div class="section-content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn-primary btn-lg">
          {{ section.settings.button_text }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Look Good Without Even Trying"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Every shirt is pre-shrunk, pre-softened, and printed with eco-friendly inks that never crack or peel. Just throw it on and go - you'll look like you spent way more than you did."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Find Your New Favorite Tee"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Rich Text"
    }
  ]
}
{% endschema %}
