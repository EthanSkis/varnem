<section class="rich-text-section" style="background: {{ section.settings.background_color }};">
  <div class="container">
    <div class="section-content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn-primary">{{ section.settings.button_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Life's Too Short for Boring Shirts"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Every shirt tells a story. Whether you're looking for something that sparks a conversation, shows off your sense of humor, or just feels incredibly comfortable — we've got you covered. Our designs are printed on premium cotton tees that get softer with every wash."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Browse the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Rich Text"
    }
  ]
}
{% endschema %}
