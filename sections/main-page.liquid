<section style="padding: var(--spacing-xl) 0;">
  <div class="container">
    <div style="max-width: 800px; margin: 0 auto;">
      <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: var(--spacing-md);">{{ page.title }}</h1>
      <div style="line-height: 1.8; color: var(--color-text-light);">
        {{ page.content }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "settings": []
}
{% endschema %}
