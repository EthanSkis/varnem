<section style="padding: var(--spacing-xl) 0;">
  <div class="container">
    <div class="section-header">
      <h1 style="font-size: 2.5rem; font-weight: 800;">Collections</h1>
    </div>

    <div class="products-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <a href="{{ collection.url }}" class="product-card">
            <div class="product-card-image">
              {% if collection.image != blank %}
                {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {% else %}
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--color-bg-alt);">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              {% endif %}
            </div>
            <div class="product-card-body">
              <h3 class="product-card-title">{{ collection.title }}</h3>
              <div class="product-card-vendor">{{ collection.products_count }} products</div>
            </div>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections List",
  "tag": "section",
  "settings": []
}
{% endschema %}
